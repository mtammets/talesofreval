PORT=5020
NODE_ENV=development

# Optional persistent storage outside the repo, recommended on Zone production.
# Example:
# APP_STORAGE_DIR=/data01/virt72693/domeenid/www.talesofreval.ee/app-storage
# APP_STORAGE_DIR=

# Zone production default:
# SMTP_HOST=localhost
# SMTP_PORT=25
# SMTP_SECURE=false
# SMTP_REJECT_UNAUTHORIZED=false

# Local real email testing:
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password-or-app-password
# SMTP_REJECT_UNAUTHORIZED=true

# Where form notifications go
MAIL_TO=info@talesofreval.ee

# Optional hidden copy recipient for every outgoing email
# MAIL_BCC=mtammets@gmail.com

# Verified sender address used by your SMTP server
MAIL_FROM=info@talesofreval.ee

# Visible sender name shown in inboxes
MAIL_FROM_NAME=Tales of Reval
# Alternatively, you can set MAIL_FROM directly as `Tales of Reval <info@talesofreval.ee>`.

# Signature values used in client emails
MAIL_SIGNATURE_NAME=Tales of Reval
MAIL_SIGNATURE_PHONE=+372 5560 4421
MAIL_WEBSITE=https://www.talesofreval.ee

# Preview/staging only. Keeps preview pages out of search indexes.
PREVIEW_NOINDEX=false

# Zone Node.js preview/staging only. Use the virtual server loopback IP.
# BIND_HOST=127.1.67.5

# Lightweight inline story editor
# Login uses only the admin password.
ADMIN_SESSION_SECRET=

# Optional legacy fallback. Prefer ADMIN_PASSWORD_HASH instead.
# ADMIN_PASSWORD=change-this-before-production

# Recommended production password hash format:
# scrypt$<saltBase64>$<hashBase64>
# Example generator:
# node -e "const crypto=require('crypto'); const salt=crypto.randomBytes(16); const hash=crypto.scryptSync('change-this-before-production', salt, 64); console.log(`scrypt$${salt.toString('base64')}$${hash.toString('base64')}`)"
ADMIN_PASSWORD_HASH=

# Optional admin login throttling
ADMIN_SESSION_TTL_SECONDS=43200
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_MS=900000
